{
  "name": "bucket",
  "version": "0.1.0",
  "description": "Access any of the popular file storage solutions with a unified API:",
  "repository": "github:franciscop/bucket",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "start": "bun test --watch",
    "lint": "prettier --check .",
    "test": "npm run lint && bun test --timeout 30000",
    "emulators:up": "docker compose -f docker-compose.emulators.yml up -d",
    "emulators:down": "docker compose -f docker-compose.emulators.yml down -v",
    "emulators:setup": "DOTENV_CONFIG_PATH=.env.emulators bun test/setup-emulators.ts",
    "test:emulators": "npm run emulators:setup && DOTENV_CONFIG_PATH=.env.emulators bun test test/index.test.ts --timeout 30000",
    "build": "bun run build.ts"
  },
  "main": "index.js",
  "type": "module",
  "dependencies": {
    "dotenv": "^16.0.0",
    "fch": "^5.1.5",
    "hash-it": "^6.0.0",
    "swear": "^1.1.0"
  },
  "devDependencies": {
    "@types/aws4": "^1.11.6",
    "@types/bun": "^1.3.0",
    "@types/node": "^25.5.2",
    "aws4": "^1.13.2",
    "axios": "^1.7.2",
    "azurite": "^3.35.0",
    "files": "^2.1.1",
    "jest": "29.7",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "xml-js": "^1.6.11"
  },
  "jest": {
    "testEnvironment": "jest-environment-node",
    "transform": {}
  }
}
