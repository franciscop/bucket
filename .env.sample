# Real cloud credentials for the integration suite (test/index.test.ts).
# To test S3/R2/GCS/Azure WITHOUT credentials, use the emulators instead. See
# .env.emulators and the "Testing" section of the readme.

FILESYSTEM_NAME=./test/bucket/

B2_BUCKET=
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_SEEDED=

AWS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_ENDPOINT=
AWS_SEEDED=

# Must include the bucket name at the end
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=
R2_SEEDED=

# Either provide client_email + private_key, or a path to a service account JSON file
GCS_BUCKET=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
GCS_CREDENTIALS=
GCS_SEEDED=

AZURE_ACCOUNT=
AZURE_CONTAINER=
AZURE_KEY=
AZURE_ENDPOINT=
AZURE_SEEDED=

# GCS_ENDPOINT + GCS_ANONYMOUS point the GCS provider at an emulator
# (fake-gcs-server). AWS_ENDPOINT / R2_ENDPOINT do the same for MinIO.
